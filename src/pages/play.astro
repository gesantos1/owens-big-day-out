---
import PhaserGame from '../components/PhaserGame';
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="apple-touch-icon" sizes="180x180" href="/favicons/apple-touch-icon.png" />
		<link rel="icon" type="image/png" sizes="32x32" href="/favicons/favicon-32x32.png" />
		<link rel="icon" type="image/png" sizes="16x16" href="/favicons/favicon-16x16.png" />
		<link rel="manifest" href="/favicons/site.webmanifest" />
		<link rel="shortcut icon" href="/favicons/favicon.ico" />
		<meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no, viewport-fit=cover" />
		<title>Owen's BIG Day Out! — Play</title>
		<!-- PWA / Standalone mode -->
		<meta name="apple-mobile-web-app-capable" content="yes" />
		<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
		<meta name="mobile-web-app-capable" content="yes" />
		<meta property="og:type" content="website" />
		<meta property="og:title" content="Owen's BIG Day Out!" />
		<meta property="og:description" content="A happy retro adventure for kids — explore Philadelphia with Owen!" />
		<style>
			* { margin: 0; padding: 0; box-sizing: border-box; }
			html, body {
				width: 100%;
				height: 100dvh;
				overflow: hidden;
				background: #1a1a2e;
			}
			#fullscreen-btn {
				display: none;
				position: fixed;
				top: 10px;
				left: 50%;
				transform: translateX(-50%);
				z-index: 2000;
				padding: 8px 16px;
				font-family: 'Press Start 2P', monospace;
				font-size: 10px;
				background: rgba(0,0,0,0.7);
				color: #4ac34a;
				border: 2px solid #4ac34a;
				border-radius: 4px;
				cursor: pointer;
			}
			#ios-prompt {
				display: none;
				position: fixed;
				bottom: 20px;
				left: 50%;
				transform: translateX(-50%);
				z-index: 2000;
				padding: 12px 16px;
				font-family: 'Press Start 2P', monospace;
				font-size: 8px;
				line-height: 1.6;
				background: rgba(0,0,0,0.9);
				color: #fff;
				border: 2px solid #4ac3ff;
				border-radius: 8px;
				text-align: center;
				max-width: 90%;
			}
			#ios-prompt .close {
				position: absolute;
				top: 4px;
				right: 8px;
				background: none;
				border: none;
				color: #ff6b6b;
				font-size: 12px;
				cursor: pointer;
			}
			@media (max-width: 900px) {
				#fullscreen-btn { display: block; }
			}
			@media (display-mode: standalone), (display-mode: fullscreen) {
				#fullscreen-btn, #ios-prompt { display: none !important; }
			}
		</style>
	</head>
	<body>
		<button id="fullscreen-btn">⛶ FULLSCREEN</button>
		<div id="ios-prompt">
			For best experience on iPhone:<br />
			Tap <strong>Share</strong> → <strong>Add to Home Screen</strong>
			<button class="close">✕</button>
		</div>
		<PhaserGame client:only="react" />
		<script>
			const fsBtn = document.getElementById('fullscreen-btn');
			const iosPrompt = document.getElementById('ios-prompt');

			const isIOS = /iPad|iPhone|iPod/.test(navigator.userAgent);
			const isStandalone = window.matchMedia('(display-mode: standalone)').matches || (window.navigator as any).standalone;

			if (isIOS && !isStandalone && iosPrompt && fsBtn) {
				iosPrompt.style.display = 'block';
				fsBtn.style.display = 'none';
			}

			iosPrompt?.querySelector('.close')?.addEventListener('click', () => {
				if (iosPrompt) iosPrompt.style.display = 'none';
			});

			fsBtn?.addEventListener('click', () => {
				const elem = document.documentElement;
				if (elem.requestFullscreen) {
					elem.requestFullscreen();
				} else if ((elem as any).webkitRequestFullscreen) {
					(elem as any).webkitRequestFullscreen();
				}
				fsBtn.style.display = 'none';
			});

			document.addEventListener('fullscreenchange', () => {
				if (document.fullscreenElement && fsBtn) {
					fsBtn.style.display = 'none';
				}
			});
		</script>
	</body>
</html>
